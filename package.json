{
	"name": "dotcom",
	"version": "0.0.1",
	"description": "Personal website for Adam Robinson, Senior Software Engineer.",
	"author": "Adam Robinson",
	"private": true,
	"scripts": {
		"dev": "vite dev --open",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"check:lighthouse": "node scripts/lighthouse-check.mjs",
		"check:seo": "unlighthouse-ci --site ${SITE_URL:-https://www.adamrobinson.tech} --config-file unlighthouse.config.ts --build-static",
		"check:bundle-budget": "node scripts/bundle-budget-check.mjs",
		"check:links": "node scripts/link-check.mjs",
		"check:blog-drafts": "node scripts/blog-draft-readiness.mjs",
		"check:dead-code": "knip --reporter compact",
		"test": "vitest run"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@sveltejs/kit": "^2.69.3",
		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"@types/node": "^25.9.2",
		"@types/sanitize-html": "^2.16.1",
		"@unlighthouse/cli": "^0.18.0",
		"@unlighthouse/core": "^0.18.0",
		"eslint": "^10.7.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.20.0",
		"globals": "^17.7.0",
		"knip": "^6.26.0",
		"prettier": "^3.9.5",
		"prettier-plugin-svelte": "^4.1.1",
		"svelte": "^5.56.5",
		"svelte-check": "^4.7.2",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.64.0",
		"vite": "^8.1.4",
		"vitest": "^4.1.10"
	},
	"type": "module",
	"overrides": {
		"cookie": "^1.0.2",
		"svix": "^1.92.2",
		"uuid": "^14.0.0"
	},
	"dependencies": {
		"@react-email/render": "^2.1.0",
		"@sveltejs/adapter-vercel": "^6.3.4",
		"@tailwindcss/vite": "^4.3.2",
		"@upstash/redis": "^1.38.0",
		"@vercel/speed-insights": "^2.0.0",
		"fast-xml-parser": "^5.10.0",
		"gray-matter": "^4.0.3",
		"marked": "^18.0.6",
		"resend": "^6.17.2",
		"sanitize-html": "2.17.6",
		"sitemap": "^9.0.1",
		"tailwindcss": "^4.3.2"
	}
}
